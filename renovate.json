{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "timezone": "Europe/London",
  "assignees": [
    "MattWhite-personal"
  ],
  "vulnerabilityAlerts": {
    "labels": ["security"],
    "automerge": false
  },
  "osvVulnerabilityAlerts": true,
  "dependencyDashboardOSVVulnerabilitySummary": "all",
  "semanticCommits": "enabled",
  "semanticCommitType": "chore",
  "semanticCommitScope": "deps",
  "prConcurrentLimit": 10,
  "prHourlyLimit": 7,
  "minimumReleaseAgeBehaviour": "timestamp-required",
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 4am on monday"]
  },
  "packageRules": [
    {
      "description": "Wait 3 days for patch releases",
      "matchUpdateTypes": ["patch"],
      "minimumReleaseAge": "3 days"
      "semanticCommitType": "fix"
    },
    {
      "description": "Wait 7 days for minor releases",
      "matchUpdateTypes": ["minor"],
      "minimumReleaseAge": "7 days"
      "semanticCommitType": "feat"
    },
    {
      "description": "Wait 30 days for major releases",
      "matchUpdateTypes": ["major"],
      "minimumReleaseAge": "30 days"
      "semanticCommitType": "feat"
    },
    {
      "description": "Group Astro Updates together",
      "matchManagers": ["npm"],
      "groupName": "Astro Packages",
      "matchUpdateTypes": ["patch","minor"]
    },
    {
      "description": "Require manual aproval - Astro major updates",
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["major"],
      "dependencyDashboardApproval": true,
    },
    {
      "description": "Group AzureRM Terraform Updates",
      "matchManagers": ["terraform"],
      "groupName": "Terraform AzureRM provder",
      "matchUpdateTypes": ["patch","minor"],
      "matchPackageNames": [
        "hashicorp/azurerm"
      ]
    },
    {
      "description": "Require manual aproval - Terraform AzureRM Major Updates",
      "matchManagers": ["terraform"],
      "matchUpdateTypes": ["major"],
      "dependencyDashboardApproval": true,
      "matchPackageNames": [
        "hashicorp/azurerm"
      ]
    },
    {
      "description": "Group AzureAD Terraform Updates",
      "matchManagers": ["terraform"],
      "groupName": "Terraform AzureAD provder",
      "matchUpdateTypes": ["patch","minor"],
      "matchPackageNames": [
        "hashicorp/azuread"
      ]
    },
    {
      "description": "Require manual aproval - Terraform AzureAD Major Updates",
      "matchManagers": ["terraform"],
      "matchUpdateTypes": ["major"],
      "dependencyDashboardApproval": true,
      "matchPackageNames": [
        "hashicorp/azuread"
      ]
    },
    {
      "description": "Group GitHub Actions",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["patch","minor"],
      "groupName": "Github Actions"
    },
    {
      "description": "Require manual Approcal - Github Actions Major Updates",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["major"],
      "dependencyDashboardApproval": true
    },
    {
      "description": "Pin Github Actions to commit SHA",
      "matchManagers": ["github-actions"],
      "pinDigests": true
    },
    {
      "description": "Set npm strategy to bump",
      "matchDatasources": ["npm"],
      "rangeStrategy": "bump"
    }
  ]
}
